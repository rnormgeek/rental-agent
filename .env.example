# ── Required ──────────────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=my-project-id
SERVICE_BASE_URL=https://rental-agent-xyz-ew.a.run.app

# ── Optional (defaults shown) ─────────────────────────────────────────────────
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

MIN_SCORE_TO_NOTIFY=50
APPROVAL_TTL_HOURS=48

FIRESTORE_COLLECTION=approvals
PUBSUB_TOPIC=rental-emails-topic
GCS_BUCKET=my-project-id-rental-agent-screenshots

# Comma-separated list of sender addresses to treat as rental alerts
RENTAL_ALERT_SENDERS=alerte@seloger.com,notifications@seloger.com

# ── Secret Manager — IDs of the secrets (not the values themselves) ───────────
SECRET_GMAIL_REFRESH_TOKEN=gmail-refresh-token
SECRET_GMAIL_CLIENT_ID=gmail-client-id
SECRET_GMAIL_CLIENT_SECRET=gmail-client-secret
SECRET_USER_EMAIL=user-email
SECRET_USER_NAME=user-name

# ── Local dev only ────────────────────────────────────────────────────────────
# Set to "true" to skip Pub/Sub OIDC token verification when testing locally
PUBSUB_SKIP_AUTH=false
